# 가장 쉬운 방법: setup.ps1 (Windows) 또는 ./setup.sh (Linux/Mac/NAS) 를 한 번 실행하면
# 아래 DB_PASSWORD/JWT_SECRET 가 강한 무작위 값으로 자동 생성된 .env 가 만들어지고 바로 시작됩니다.
# 직접 만들 거면 이 파일을 .env 로 복사한 뒤 두 값을 길고 무작위로 바꾸세요(환자 데이터 전 필수).
DB_PASSWORD=change_this_database_password
JWT_SECRET=change_this_long_random_secret

# ── 백업 (선택) ───────────────────────────────────────────────
# BACKUP_PATH 를 비워두면 백업이 꺼집니다(opt-in). 앱은 C에 설치하고 백업만 D로 빼는 식.
#   Windows 예:  BACKUP_PATH=D:\medconnect-backups
#   NAS 예:      BACKUP_PATH=/volume2/medconnect-backups
BACKUP_PATH=
BACKUP_RETENTION_DAYS=30
BACKUP_TIME=02:00
TZ=Indian/Antananarivo
